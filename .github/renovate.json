{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "ignorePresets": [
        ":ignoreModulesAndTests",
        "mergeConfidence:all-badges"
    ],
    "labels": [
        "dependency",
        "build"
    ],
    "commitMessagePrefix": "Build: ",
    "vulnerabilityAlerts": {
        "enabled": true,
        "addLabels": [
            "security"
        ]
    },
    "packageRules": [
        {
            "matchPackageNames": [
                "Microsoft.CodeAnalysis**"
            ],
            "groupName": "code-analysis monorepo"
        },
        {
            "matchPackageNames": [
                "Microsoft.CodeAnalysis.CSharp"
            ],
            "enabled": false
        },
        {
            "matchFileNames": [
                "src/MudBlazor.Analyzers.CodeFixes/MudBlazor.Analyzers.CodeFixes.csproj"
            ],
            "matchPackageNames": [
                "Microsoft.CodeAnalysis.CSharp.Workspaces"
            ],
            "enabled": false
        },
        {
            "description": "Keep updates in draft while release age is unknown or immature.",
            "matchJsonata": [
                "$exists(newVersionAgeInDays) = false or newVersionAgeInDays < 14"
            ],
            "draftPR": true,
            "prBodyNotes": [
                "> [!WARNING]\n> Target version is either under 14 days old or does not publish a reliable release timestamp yet."
            ]
        },
        {
            "description": "Keep updates in draft when merge confidence is low.",
            "matchConfidence": [
                "low",
                "very low"
            ],
            "draftPR": true,
            "prBodyNotes": [
                "> [!WARNING]\n> Renovate reported low merge confidence for this update."
            ]
        },
        {
            "matchFileNames": [
                "src/MudBlazor/MudBlazor.csproj"
            ],
            "matchPackageNames": [
                "Microsoft.AspNetCore**",
                "Microsoft.Extensions**"
            ],
            "enabled": false
        },
        {
            "description": "Group Bun toolchain updates and request Bun reviewer.",
            "matchManagers": [
                "custom.regex"
            ],
            "matchPackageNames": [
                "bun",
                "BunDotNet.Cli"
            ],
            "matchFileNames": [
                "src/Directory.Build.props"
            ],
            "groupName": "bun toolchain",
            "groupSlug": "bun-toolchain",
            "separateMajorMinor": false,
            "separateMultipleMajor": false,
            "reviewers": [
                "meenzen"
            ]
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)Directory\\.Build\\.props$/"
            ],
            "matchStrings": [
                "<BunVersion>(?<currentValue>.*?)</BunVersion>"
            ],
            "depNameTemplate": "bun",
            "datasourceTemplate": "npm"
        },
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)Directory\\.Build\\.props$/"
            ],
            "matchStrings": [
                "<BunDotNetVersion>(?<currentValue>.*?)</BunDotNetVersion>"
            ],
            "depNameTemplate": "BunDotNet.Cli",
            "datasourceTemplate": "nuget"
        }
    ]
}
