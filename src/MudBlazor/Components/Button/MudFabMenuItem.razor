@namespace MudBlazor
@inherits MudFab

<MudFab Class="@Classname"
        Style="@Style"
        Color="@Color"
        Size="@Size"
        StartIcon="@StartIcon"
        EndIcon="@EndIcon"
        IconColor="@IconColor"
        IconSize="@IconSize"
        Label="@Label"
        ButtonType="@ButtonType"
        Href="@Href"
        Target="@Target"
        HtmlTag="@HtmlTag"
        Rel="@Rel"
        Disabled="@Disabled"
        ClickPropagation="true"
        DropShadow="@DropShadow"
        Ripple="@Ripple"
        @attributes="@UserAttributes"
        @onclick="this.AsNonRenderingEventHandler<MouseEventArgs>(OnClickHandler)"
        role="menuitem"/>
