<MudFileUpload T="IBrowserFile" Disabled="Disabled">
    <CustomContent>
        <MudButton OnClick="@context.OpenFilePickerAsync">
            Upload
        </MudButton>
    </CustomContent>
</MudFileUpload>

@code {
    public static string __description__ = "Tests that file upload respects the disabled state with custom activator content.";

    [Parameter]
    public bool Disabled { get; set; }
}
